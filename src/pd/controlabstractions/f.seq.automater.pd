#X text 205 60 <- move this out of the abstraction???;
#X text 549 472 looptrig = determines whether automation runs freely \, is triggered by sequence step or at the beginning of each sequence cycle;
#X text 549 518 trig = receives a bang each time a step of the sequence is triggered;
#X text 549 553 reset = resets all values;
#X text 549 577 float(value-in) = sets the parameter value as controlled by the UI in open stage control;
#X text 549 612 active = activate/deactivate automation read back;
#X text 549 636 slew = sets chaos slew;
